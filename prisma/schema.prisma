// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Float
  originalPrice Float?
  category      String
  image         String
  features      String   // JSON string of features array
  tags          String   @default("[]") // JSON string of tags array
  isFeatured    Boolean  @default(false)
  version       String   @default("1.0.0")
  framework     String   @default("ESX / QBCore")
  rating        Float    @default(5.0)
  salesCount    Int      @default(0)
  lastUpdated   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cartItems     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  quantity  Int      @default(1)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Order {
  id         String      @id @default(cuid())
  email      String
  name       String
  totalPrice Float
  subtotal   Float       @default(0)
  discount   Float       @default(0)
  promoCode  String?
  status     String      @default("completed")
  items      OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  discountType String  @default("percent") // "percent" | "fixed"
  discountValue Float
  minOrder    Float    @default(0)
  maxUses     Int      @default(0) // 0 = unlimited
  usesCount   Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int     @default(1)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  name      String
  rating    Int
  title     String
  comment   String
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
}
