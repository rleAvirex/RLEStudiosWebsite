# ── Database ────────────────────────────────────────────────────
# Neon (or any Postgres) connection string.
# Use the pooled connection in production; keep UNPOOLED for migrations if needed.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"

# ── Admin dashboard ─────────────────────────────────────────────
# Password required to access /admin (the admin login form).
ADMIN_PASSWORD="change-me"
# Secret used to HMAC-sign the admin auth cookie. Any long random string.
ADMIN_SECRET="change-me-to-a-long-random-string"

# ── NextAuth (magic-code login) ─────────────────────────────────
# Used to sign JWT sessions. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Email (Resend) — required for production magic-code login ───
# Get a key at https://resend.com. Without this, login codes only
# appear on screen in dev mode and are NOT delivered in production.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Sender address. Must be a verified domain in Resend, or use the
# Resend sandbox sender for local testing:
MAIL_FROM="RLE Studios <onboarding@resend.dev>"
